{
    "compilerOptions": {
      "target": "ES2022",
      "module": "ES2022",
      "outDir": "./dist",
      "rootDir": "./src",
      "moduleResolution": "bundler",
      "esModuleInterop": true,
      "moduleDetection": "force",
      "strict": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "resolveJsonModule": true,
      "isolatedModules": true,
      "noEmit": false,
      "baseUrl": ".",
      // "paths": {
      //   "~/*": ["./src/*"]
      // },
      "types": ["node"],
      "lib": ["ES2022"],
      "composite": true
    },
    "include": ["src/**/*", "src/**/*.json"],
    "exclude": [
      "node_modules",
      "dist",
      "**/*.spec.ts",
      "**/*.test.ts",
      "**/*.d.ts"
    ]
  }